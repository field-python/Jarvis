# ── sensitive config (entire directory — new files auto-protected) ────────────
config/*
!config/.gitkeep

# ── personal data (entire memory directory — all personalization files) ────────
memory/*
!memory/.gitkeep

# ── personal notes and session data ──────────────────────────────────────────
notes/personal-notes/
notes/voice-sessions/
notes/saved-answers/
notes/lessons/
notes/web-cache/

# ── voice models (downloaded locally, not committed) ─────────────────────────
voice/*.onnx
voice/*.onnx.json

# ── large archive content (users build their own) ─────────────────────────────
# Keep only the .gitkeep placeholder — all note content stays local
notes/*
!notes/.gitkeep
pages/

# ── semantic search index (rebuilt locally) ───────────────────────────────────
chroma_db/

# ── cache ─────────────────────────────────────────────────────────────────────
cache/
.cache/

# ── large local knowledge base (too large for GitHub, built locally) ──────────
wikipedia/
pdfs/

# ── python ────────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/

# ── generated code output ─────────────────────────────────────────────────────
jarvis-code/

# ── misc ──────────────────────────────────────────────────────────────────────
*.log
.DS_Store
*.tmp
